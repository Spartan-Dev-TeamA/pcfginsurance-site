---
---

<header class="bg-white shadow-lg sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center py-4">
      <!-- Logo -->
      <div class="flex items-center">
        <a href="/" class="flex items-center">
          <div class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center mr-3">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <div>
            <div class="text-xl font-bold text-neutral-dark font-heading">PCFG Insurance</div>
            <div class="text-xs text-neutral-dark">Veteran-Owned & Operated</div>
          </div>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center space-x-8">
        <div class="relative group">
          <button class="flex items-center text-neutral-dark hover:text-primary font-medium transition-colors duration-200">
            Business Insurance
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="absolute left-0 mt-2 w-64 bg-white rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <div class="py-2">
              <a href="/workers-compensation" class="block px-4 py-3 text-sm text-neutral-dark hover:bg-primary-50 hover:text-primary transition-colors">
                <div class="font-medium">Workers' Compensation</div>
                <div class="text-xs text-neutral-dark">Protect your employees</div>
              </a>
              <a href="/commercial-auto" class="block px-4 py-3 text-sm text-neutral-dark hover:bg-primary-50 hover:text-primary transition-colors">
                <div class="font-medium">Commercial Auto</div>
                <div class="text-xs text-neutral-dark">Fleet & vehicle coverage</div>
              </a>
              <a href="/general-liability" class="block px-4 py-3 text-sm text-neutral-dark hover:bg-primary-50 hover:text-primary transition-colors">
                <div class="font-medium">General Liability</div>
                <div class="text-xs text-neutral-dark">Third-party protection</div>
              </a>
              <a href="/business-owners-policy" class="block px-4 py-3 text-sm text-neutral-dark hover:bg-primary-50 hover:text-primary transition-colors">
                <div class="font-medium">Business Owner's Policy</div>
                <div class="text-xs text-neutral-dark">Combined coverage</div>
              </a>
            </div>
          </div>
        </div>

        <div class="relative group">
          <button class="flex items-center text-neutral-dark hover:text-primary font-medium transition-colors duration-200">
            Personal Insurance
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="absolute left-0 mt-2 w-56 bg-white rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <div class="py-2">
              <a href="/personal-lines-quote" class="block px-4 py-3 text-sm text-neutral-dark hover:bg-primary-50 hover:text-primary transition-colors">
                <div class="font-medium">Auto Insurance</div>
                <div class="text-xs text-neutral-dark">Personal vehicle coverage</div>
              </a>
              <a href="/personal-lines-quote" class="block px-4 py-3 text-sm text-neutral-dark hover:bg-primary-50 hover:text-primary transition-colors">
                <div class="font-medium">Home Insurance</div>
                <div class="text-xs text-neutral-dark">Homeowners protection</div>
              </a>
              <a href="/personal-lines-quote" class="block px-4 py-3 text-sm text-neutral-dark hover:bg-primary-50 hover:text-primary transition-colors">
                <div class="font-medium">Renters Insurance</div>
                <div class="text-xs text-neutral-dark">Tenant coverage</div>
              </a>
            </div>
          </div>
        </div>

        <a href="/services" class="text-neutral-dark hover:text-primary font-medium transition-colors duration-200">Services</a>
        <a href="/contact" class="text-neutral-dark hover:text-primary font-medium transition-colors duration-200">Contact</a>
        <a href="/careers" class="text-neutral-dark hover:text-primary font-medium transition-colors duration-200">Careers</a>
      </nav>

      <!-- Contact Info & CTA -->
      <div class="hidden lg:flex items-center space-x-4">
        <div class="text-right">
          <div class="text-sm font-semibold text-neutral-dark">(877) 717-7234</div>
          <div class="text-xs text-neutral-dark">Licensed in 15 States</div>
        </div>
        <a href="/contact" class="bg-primary hover:bg-primary-dark text-white px-6 py-2 rounded-lg font-medium transition-colors duration-200">
          Get Quote
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-button" class="lg:hidden p-2 text-neutral-dark hover:text-primary transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-white border-t border-neutral-200">
    <div class="px-4 py-4 space-y-4">
      <!-- Business Insurance -->
      <div>
        <button class="flex items-center justify-between w-full text-left text-neutral-dark font-medium py-2 mobile-dropdown-toggle">
          Business Insurance
          <svg class="w-4 h-4 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
        <div class="mobile-dropdown hidden pl-4 mt-2 space-y-2">
          <a href="/workers-compensation" class="block py-2 text-sm text-neutral-dark hover:text-primary transition-colors">Workers' Compensation</a>
          <a href="/commercial-auto" class="block py-2 text-sm text-neutral-dark hover:text-primary transition-colors">Commercial Auto</a>
          <a href="/general-liability" class="block py-2 text-sm text-neutral-dark hover:text-primary transition-colors">General Liability</a>
          <a href="/business-owners-policy" class="block py-2 text-sm text-neutral-dark hover:text-primary transition-colors">Business Owner's Policy</a>
        </div>
      </div>

      <!-- Personal Insurance -->
      <div>
        <button class="flex items-center justify-between w-full text-left text-neutral-dark font-medium py-2 mobile-dropdown-toggle">
          Personal Insurance
          <svg class="w-4 h-4 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
        <div class="mobile-dropdown hidden pl-4 mt-2 space-y-2">
          <a href="/personal-lines-quote" class="block py-2 text-sm text-neutral-dark hover:text-primary transition-colors">Auto Insurance</a>
          <a href="/personal-lines-quote" class="block py-2 text-sm text-neutral-dark hover:text-primary transition-colors">Home Insurance</a>
          <a href="/personal-lines-quote" class="block py-2 text-sm text-neutral-dark hover:text-primary transition-colors">Renters Insurance</a>
        </div>
      </div>

      <a href="/services" class="block py-2 text-neutral-dark hover:text-primary font-medium transition-colors">Services</a>
      <a href="/contact" class="block py-2 text-neutral-dark hover:text-primary font-medium transition-colors">Contact</a>
      <a href="/careers" class="block py-2 text-neutral-dark hover:text-primary font-medium transition-colors">Careers</a>

      <!-- Mobile CTA -->
      <div class="pt-4 border-t border-neutral-200">
        <div class="flex items-center justify-between mb-3">
          <span class="text-sm font-semibold text-neutral-dark">(877) 717-7234</span>
          <span class="text-xs text-neutral-dark">Licensed in 15 States</span>
        </div>
        <a href="/contact" class="block w-full text-center bg-primary hover:bg-primary-dark text-white py-3 rounded-lg font-medium transition-colors duration-200">
          Get Free Quote
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Mobile menu toggle
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    
    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.addEventListener('click', function() {
        mobileMenu.classList.toggle('hidden');
        
        // Update button icon
        const icon = this.querySelector('svg path');
        if (mobileMenu.classList.contains('hidden')) {
          icon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
        } else {
          icon.setAttribute('d', 'M6 18L18 6M6 6l12 12');
        }
      });
    }
    
    // Mobile dropdown toggles
    document.querySelectorAll('.mobile-dropdown-toggle').forEach(button => {
      button.addEventListener('click', function() {
        const dropdown = this.nextElementSibling;
        const icon = this.querySelector('svg');
        
        dropdown.classList.toggle('hidden');
        icon.classList.toggle('rotate-180');
      });
    });
    
    // Close mobile menu when clicking on links
    document.querySelectorAll('#mobile-menu a').forEach(link => {
      link.addEventListener('click', function() {
        mobileMenu.classList.add('hidden');
        const icon = mobileMenuButton.querySelector('svg path');
        icon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
      });
    });
  });
</script>