<script is:inline>
// Tell TS to chill
// @ts-nocheck

document.addEventListener('DOMContentLoaded', function() {
  let currentStep = 1;
  const totalSteps = 5;

  const form = document.getElementById('personal-lines-quote-form') as HTMLFormElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const saveProgressBtn = document.getElementById('save-progress-btn') as HTMLButtonElement;
  const clearFormBtn = document.getElementById('clear-form-btn') as HTMLButtonElement;

  // Update progress indicators
  function updateProgress() {
    const progressPercentage = (currentStep / totalSteps) * 100;
    (document.getElementById('progress-bar') as HTMLElement).style.width = progressPercentage + '%';
    (document.getElementById('current-step-number') as HTMLElement).textContent = String(currentStep);
    (document.getElementById('progress-percentage') as HTMLElement).textContent = String(Math.round(progressPercentage));

    for (let i = 1; i <= totalSteps; i++) {
      const indicator = document.getElementById(`step-${i}-indicator`);
      const circle = indicator?.querySelector('.w-8') as HTMLElement;
      if (!circle) continue;

      if (i < currentStep) {
        indicator!.className = 'flex items-center step-indicator completed';
        circle.className = 'w-8 h-8 rounded-full bg-green-600 text-white flex items-center justify-center text-sm font-medium';
        circle.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
      } else if (i === currentStep) {
        indicator!.className = 'flex items-center step-indicator active';
        circle.className = 'w-8 h-8 rounded-full bg-orange-600 text-white flex items-center justify-center text-sm font-medium';
        circle.textContent = String(i);
      } else {
        indicator!.className = 'flex items-center step-indicator';
        circle.className = 'w-8 h-8 rounded-full bg-gray-300 text-gray-600 flex items-center justify-center text-sm font-medium';
        circle.textContent = String(i);
      }
    }
  }

  function showStep(step: number) {
    document.querySelectorAll('.form-step').forEach(s => s.classList.remove('active'));
    (document.getElementById(`step-${step}`) as HTMLElement).classList.add('active');

    prevBtn.classList.toggle('hidden', step === 1);
    nextBtn.classList.toggle('hidden', step === totalSteps);
    submitBtn.classList.toggle('hidden', step !== totalSteps);

    updateProgress();
    if (step === 4) updateInsuranceDetails();
    if (step === 5) populateReviewContent();
  }

  function validateStep(step: number) {
    const stepElement = document.getElementById(`step-${step}`)!;
    const requiredFields = stepElement.querySelectorAll('input[required], select[required]');
    let isValid = true;

    requiredFields.forEach(field => {
      const input = field as HTMLInputElement | HTMLSelectElement;
      if (!input.value.trim()) {
        input.classList.add('border-red-500');
        isValid = false;
      } else {
        input.classList.remove('border-red-500');
      }
    });

    if (step === 3) {
      const insuranceTypes = document.querySelectorAll<HTMLInputElement>('input[name="insurance-types"]:checked');
      if (insuranceTypes.length === 0) {
        alert('Please select at least one type of insurance.');
        isValid = false;
      }
    }
    return isValid;
  }

  function updateInsuranceDetails() {
    const autoSelected = (document.querySelector('input[name="insurance-types"][value="auto"]') as HTMLInputElement)?.checked;
    const homeSelected = (document.querySelector('input[name="insurance-types"][value="home"]') as HTMLInputElement)?.checked;

    document.getElementById('auto-details')?.classList.toggle('hidden', !autoSelected);
    document.getElementById('home-details')?.classList.toggle('hidden', !homeSelected);
  }

  function populateReviewContent() {
    const reviewContent = document.getElementById('review-content')!;
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    const insuranceTypes = Array.from(document.querySelectorAll<HTMLInputElement>('input[name="insurance-types"]:checked')).map(cb => cb.value);

    reviewContent.innerHTML = `
      <div class="bg-white border border-gray-200 rounded-lg p-6">
        <h4 class="text-lg font-semibold text-gray-900 mb-4">Personal Information</h4>
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div><strong>Name:</strong> ${data['first-name']} ${data['last-name']}</div>
          <div><strong>Email:</strong> ${data['email']}</div>
          <div><strong>Phone:</strong> ${data['phone']}</div>
          <div><strong>Date of Birth:</strong> ${data['date-of-birth'] || 'Not provided'}</div>
        </div>
      </div>
      <div class="bg-white border border-gray-200 rounded-lg p-6">
        <h4 class="text-lg font-semibold text-gray-900 mb-4">Address</h4>
        <div class="text-sm">
          <p>${data['street-address']}</p>
          <p>${data['city']}, ${data['state']} ${data['zip-code']}</p>
        </div>
      </div>
      <div class="bg-white border border-gray-200 rounded-lg p-6">
        <h4 class="text-lg font-semibold text-gray-900 mb-4">Insurance Types</h4>
        <div class="flex flex-wrap gap-2">
          ${insuranceTypes.map(type => `<span class="bg-orange-100 text-orange-800 px-3 py-1 rounded-full text-sm font-medium">${type}</span>`).join('')}
        </div>
      </div>`;
  }

  // Card click toggle
  document.querySelectorAll('.insurance-type-card').forEach(card => {
    card.addEventListener('click', function() {
      const checkbox = this.querySelector('input[type="checkbox"]') as HTMLInputElement;
      checkbox.checked = !checkbox.checked;
      checkbox.dispatchEvent(new Event('change'));
    });
  });

  nextBtn.addEventListener('click', () => {
    if (validateStep(currentStep) && currentStep < totalSteps) {
      currentStep++;
      showStep(currentStep);
    }
  });

  prevBtn.addEventListener('click', () => {
    if (currentStep > 1) {
      currentStep--;
      showStep(currentStep);
    }
  });

  saveProgressBtn.addEventListener('click', function() {
    const formData = new FormData(form);
    const data: Record<string, any> = Object.fromEntries(formData);
    data['insurance-types'] = Array.from(document.querySelectorAll<HTMLInputElement>('input[name="insurance-types"]:checked')).map(cb => cb.value);
    data['current-step'] = String(currentStep);
    localStorage.setItem('personalLinesQuoteProgress', JSON.stringify(data));

    const originalText = this.textContent!;
    this.textContent = 'Saved!';
    this.classList.add('bg-green-100','text-green-700');
    setTimeout(() => {
      this.textContent = originalText;
      this.classList.remove('bg-green-100','text-green-700');
    }, 2000);
  });

  clearFormBtn.addEventListener('click', () => {
    if (confirm('Are you sure you want to clear all form data?')) {
      form.reset();
      localStorage.removeItem('personalLinesQuoteProgress');
      currentStep = 1;
      showStep(currentStep);
      document.querySelectorAll<HTMLInputElement>('input[name="insurance-types"]').forEach(cb => cb.checked = false);
    }
  });

  form.addEventListener('submit', e => {
    e.preventDefault();
    if (validateStep(currentStep)) {
      const formData = new FormData(form);
      const data: Record<string, any> = Object.fromEntries(formData);
      data['insurance-types'] = Array.from(document.querySelectorAll<HTMLInputElement>('input[name="insurance-types"]:checked')).map(cb => cb.value);
      const event = new CustomEvent('personalLinesQuoteSubmit', { detail: data });
      document.dispatchEvent(event);
    }
  });

  // Load saved progress
  const savedProgress = localStorage.getItem('personalLinesQuoteProgress');
  if (savedProgress) {
    try {
      const data = JSON.parse(savedProgress);
      Object.keys(data).forEach(key => {
        if (key === 'insurance-types' && Array.isArray(data[key])) {
          data[key].forEach((value: string) => {
            const checkbox = document.querySelector(`input[name="insurance-types"][value="${value}"]`) as HTMLInputElement;
            if (checkbox) checkbox.checked = true;
          });
        } else if (key === 'current-step') {
          currentStep = parseInt(data[key]) || 1;
        } else {
          const field = form.querySelector(`[name="${key}"]`) as HTMLInputElement | HTMLSelectElement | null;
          if (field) {
            if ((field as HTMLInputElement).type === 'radio') {
              if ((field as HTMLInputElement).value === data[key]) (field as HTMLInputElement).checked = true;
            } else {
              (field as HTMLInputElement).value = data[key];
            }
          }
        }
      });
      showStep(currentStep);
    } catch (e) {
      console.error('Error loading saved progress:', e);
    }
  } else {
    showStep(1);
  }
});
</script>
