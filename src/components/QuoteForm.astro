<div class="bg-white p-6 rounded-lg shadow-lg" role="complementary" aria-labelledby="quote-form-heading">
  <h3 id="quote-form-title" class="text-xl font-semibold text-neutral-dark mb-4 font-heading">Get Your Free Quote</h3>
  <form id="quote-form" class="space-y-4" name="quick-quote" data-netlify="true" data-netlify-recaptcha="true">
    <input type="hidden" name="form-name" value="quick-quote" />
    <input type="hidden" id="user-location-state" name="user-location-state" value="" />
    <input type="hidden" id="user-location-city" name="user-location-city" value="" />

    <!-- keep your existing form fields here -->

    <div data-netlify-recaptcha="true"></div>
    <button type="submit" class="w-full bg-primary hover:bg-primary-dark text-white font-semibold py-4 px-4 rounded-lg transition-colors duration-200 text-lg shadow-md">
      <span id="quote-cta-text">Get Free Quote</span>
    </button>
  </form>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    initializeLocationAwareForm();

    const form = document.getElementById('quote-form');
    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      console.log('=== QUOTE FORM SUBMISSION STARTED ===');

      const submitButton = form.querySelector('button[type="submit"]');
      if (!submitButton) return;
      const originalButtonText = submitButton.textContent;

      submitButton.disabled = true;
      submitButton.textContent = 'Submitting...';

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      console.log('Form data collected:', data);

      try {
        // Lazy load supabase util if not cached
        if (!window.submitToSupabase) {
          const supabaseModule = await import('/src/utils/supabase.js');
          if (supabaseModule && supabaseModule.submitToSupabase) {
            window.submitToSupabase = supabaseModule.submitToSupabase;
          }
        }

        if (typeof window.submitToSupabase === 'function') {
          await window.submitToSupabase(data, 'quick_quote_form');
        }

        submitButton.textContent = 'Success!';
        submitButton.classList.replace('bg-primary', 'bg-green-600');
        await new Promise((resolve) => setTimeout(resolve, 1000));

        // Routing
        const businessTypes = ['workers-comp', 'commercial-auto', 'general-liability', 'bop', 'cyber-liability', 'professional-liability'];
        const personalTypes = ['auto-insurance', 'home-insurance', 'renters-insurance', 'condo-insurance', 'life-insurance', 'umbrella-insurance', 'motorcycle-insurance', 'boat-insurance', 'rv-insurance'];

        if (businessTypes.includes(data['insurance-type'])) {
          const params = new URLSearchParams({
            name: data['name'] || '',
            'business-name': data['business-name'] || '',
            email: data['email'] || '',
            phone: data['phone'] || '',
            'insurance-type': data['insurance-type'] || ''
          });
          window.location.href = `/commercial-quote?${params.toString()}`;
          return;
        }

        if (personalTypes.includes(data['insurance-type'])) {
          const fullName = data['name'] || '';
          const firstName = fullName.split(' ')[0] || fullName;
          const lastName = fullName.split(' ').slice(1).join(' ') || '';
          const params = new URLSearchParams({
            'first-name': firstName,
            'last-name': lastName,
            email: data['email'] || '',
            phone: data['phone'] || '',
            'insurance-type': data['insurance-type'] || ''
          });
          window.location.href = `/personal-lines-quote?${params.toString()}`;
          return;
        }

        alert('Thank you for your interest! We will contact you within 24 hours with your free quote.');
        form.reset();
      } catch (error) {
        console.error('FORM SUBMISSION ERROR:', error);
        alert('There was an error submitting your form. Please try again or call (877) 717-7234.');
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = originalButtonText;
        submitButton.classList.replace('bg-green-600', 'bg-primary');
      }
    });
  });

  async function initializeLocationAwareForm() {
    try {
      let attempts = 0;
      while (!window.locationUtils && attempts < 50) {
        await new Promise((resolve) => setTimeout(resolve, 100));
        attempts++;
      }
      if (!window.locationUtils) return;

      const locationContent = await window.locationUtils.getUserLocationContent();
      if (!locationContent) return;

      const formTitle = document.getElementById('quote-form-title');
      if (formTitle && locationContent.state && locationContent.state !== 'Multiple States') {
        formTitle.textContent = `Get Your Free ${locationContent.state} Insurance Quote`;
      }

      const ctaText = document.getElementById('quote-cta-text');
      if (ctaText && locationContent.ctaText) {
        ctaText.textContent = locationContent.ctaText;
      }

      const stateField = document.getElementById('user-location-state');
      const cityField = document.getElementById('user-location-city');
      if (stateField && locationContent.state) stateField.value = locationContent.state;
      if (cityField && locationContent.city) cityField.value = locationContent.city;

      console.log('Quote form personalized for:', locationContent);
    } catch (error) {
      console.error('Failed to initialize location-aware form:', error);
    }
  }
</script>
