</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  
  body {
    margin: 0;
    padding: 0;
    color: #212121;
    padding-bottom: 4rem; /* Add padding for mobile nav */
  }

  @media (min-width: 768px) {
    body {
      padding-bottom: 0; /* Remove padding on desktop */
    }
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Poppins', system-ui, sans-serif;
    font-weight: 700;
    color: #212121;
  }
  
  /* Mobile app-like styles */
  .card {
    @apply bg-white rounded-lg shadow-md overflow-hidden transition-all duration-200;
  }
  
  .card:active {
    @apply transform scale-95;
  }
  
  .btn {
    @apply w-full py-3 px-4 rounded-lg font-semibold transition-colors duration-200 text-center;
  }
  
  .btn-primary {
    @apply bg-primary text-white hover:bg-primary-dark;
  }
  
  .btn-secondary {
    @apply border-2 border-primary text-primary hover:bg-primary-50;
  }
  
  /* Toast notification */
  .toast {
    @apply bg-white rounded-lg shadow-lg p-4 flex items-center transform transition-all duration-300 opacity-0 translate-y-4;
  }
  
  .toast.show {
    @apply opacity-100 translate-y-0;
  }
  
  /* Page transitions */
  .page-transition-enter {
    opacity: 0;
    transform: translateY(10px);
  }
  
  .page-transition-enter-active {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 300ms, transform 300ms;
  }
  
  .page-transition-exit {
    opacity: 1;
  }
  
  .page-transition-exit-active {
    opacity: 0;
    transition: opacity 300ms;
  }
</style>

<script>
  // Import PWA utilities to ensure window.pwa is available
  import '../utils/pwa.js';
  import '../utils/netlify-forms.js';
  import '../utils/form-handler.js';
  
  // Check if we're in StackBlitz environment
  const isStackBlitz = window.location.hostname.includes('stackblitz') || 
                      window.location.hostname.includes('webcontainer') ||
                      navigator.userAgent.includes('StackBlitz');
  
  // Service Worker Registration - only if not in StackBlitz
  if ('serviceWorker' in navigator && !isStackBlitz) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('/sw.js')
        .then(registration => {
          console.log('Service Worker registered with scope:', registration.scope);
        })
        .catch(error => {
          console.error('Service Worker registration failed:', error);
        });
    });
  } else if (isStackBlitz) {
    console.log('Service Worker registration skipped - running in StackBlitz environment');
  }
  
  // Add to Home Screen Logic
  let deferredPrompt;
  const addToHomeScreen = document.getElementById('add-to-homescreen');
  const installButton = document.getElementById('install-pwa');
  const dismissButton = document.getElementById('dismiss-pwa');
  const closeButton = document.getElementById('close-pwa-prompt');
  
  window.addEventListener('beforeinstallprompt', (e) => {
    // Prevent Chrome 67 and earlier from automatically showing the prompt
    e.preventDefault();
    // Stash the event so it can be triggered later
    deferredPrompt = e;
    
    // Show the prompt after 10 seconds or after form submission
    setTimeout(() => {
      if (addToHomeScreen && !localStorage.getItem('pwaPromptDismissed')) {
        addToHomeScreen.classList.remove('hidden');
      }
    }, 10000);
  });
  
  // Handle the install button click
  if (installButton) {
    installButton.addEventListener('click', () => {
      if (deferredPrompt) {
        // Show the install prompt
        deferredPrompt.prompt();
        
        // Wait for the user to respond to the prompt
        deferredPrompt.userChoice.then((choiceResult) => {
          if (choiceResult.outcome === 'accepted') {
            console.log('User accepted the install prompt');
            window.pwa.showToast('Installing app to your home screen!', 'success');
          } else {
            console.log('User dismissed the install prompt');
          }
          // Clear the saved prompt since it can't be used again
          deferredPrompt = null;
          // Hide the install prompt
          addToHomeScreen.classList.add('hidden');
        });
      }
    });
  }
  
  // Handle dismiss button
  if (dismissButton) {
    dismissButton.addEventListener('click', () => {
      addToHomeScreen.classList.add('hidden');
      localStorage.setItem('pwaPromptDismissed', 'true');
      // Reset after 7 days
      setTimeout(() => {
        localStorage.removeItem('pwaPromptDismissed');
      }, 7 * 24 * 60 * 60 * 1000);
    });
  }
  
  // Handle close button
  if (closeButton) {
    closeButton.addEventListener('click', () => {
      addToHomeScreen.classList.add('hidden');
    });
  }
  
  // Check if the app is in standalone mode (installed)
  if (window.matchMedia('(display-mode: standalone)').matches) {
    // The app is installed and running in standalone mode
    console.log('App is running in standalone mode');
    
    // Show a welcome back message if this is not the first visit
    if (localStorage.getItem('returningPwaUser')) {
      window.pwa.showToast('Welcome back to PCFG Insurance!', 'info');
    } else {
      localStorage.setItem('returningPwaUser', 'true');
      window.pwa.showToast('Welcome to the PCFG Insurance app!', 'success');
    }
  }
  
  // Form submission success handler
  document.addEventListener('DOMContentLoaded', function() {
    const forms = document.querySelectorAll('form');
    
    forms.forEach(form => {
      const originalSubmit = form.onsubmit;
      
      form.onsubmit = async function(e) {
        if (originalSubmit) {
          const result = originalSubmit.call(this, e);
          if (result === false) return false;
        }
        
        // Show the PWA prompt after form submission
        setTimeout(() => {
          if (deferredPrompt && addToHomeScreen && !localStorage.getItem('pwaPromptDismissed')) {
            addToHomeScreen.classList.remove('hidden');
          }
        }, 1000);
        
        // Show success toast
        setTimeout(() => {
          window.pwa.showToast('Form submitted successfully!', 'success');
        }, 500);
      };
    });
  });
  
  // Detect if user is on iOS
  const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
  
  // Show iOS-specific install instructions
  if (isIOS && !window.matchMedia('(display-mode: standalone)').matches) {
    // Check if we've already shown the iOS instructions
    if (!localStorage.getItem('iosInstructionsShown')) {
      setTimeout(() => {
        window.pwa.showToast('Tap "Share" then "Add to Home Screen" to install', 'info');
        localStorage.setItem('iosInstructionsShown', 'true');
        
        // Reset after 3 days
        setTimeout(() => {
          localStorage.removeItem('iosInstructionsShown');
        }, 3 * 24 * 60 * 60 * 1000);
      }, 15000);
    }
  }
  
  // Page transition effects
  document.addEventListener('astro:before-swap', () => {
    document.documentElement.classList.add('page-transition-exit-active');
  });
  
  document.addEventListener('astro:after-swap', () => {
    document.documentElement.classList.remove('page-transition-exit-active');
    document.documentElement.classList.add('page-transition-enter');
    
    requestAnimationFrame(() => {
      document.documentElement.classList.remove('page-transition-enter');
      document.documentElement.classList.add('page-transition-enter-active');
      
      setTimeout(() => {
        document.documentElement.classList.remove('page-transition-enter-active');
      }, 300);
    });
  });

  // Disable automatic swipe navigation that might be causing the issue
  document.addEventListener('touchstart', function(e) {
    // Don't do anything special on touch start
  }, { passive: true });
  
  document.addEventListener('touchend', function(e) {
    // Don't navigate based on swipe gestures
  }, { passive: true });
</script>