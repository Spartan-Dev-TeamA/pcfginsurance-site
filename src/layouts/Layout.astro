      </div>
    </div>
    
    <!-- Chatbot Placeholder -->
    <div id="chatbot" class="fixed bottom-20 md:bottom-6 right-6 z-50">
      <button class="bg-primary hover:bg-primary-dark text-white p-4 rounded-full shadow-lg transition-colors duration-200">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
        </svg>
      </button>
    </div>
    
    <!-- Add to Home Screen Prompt -->
    <div id="add-to-homescreen" class="fixed bottom-20 md:bottom-6 left-0 right-0 mx-auto w-11/12 max-w-sm bg-white rounded-lg shadow-lg p-4 z-50 hidden">
      <div class="flex items-start">
        <div class="flex-shrink-0 pt-0.5">
          <img src="/icons/icon-192x192.png" alt="PCFG Insurance" class="h-10 w-10 rounded-lg">
        </div>
        <div class="ml-3 flex-1">
          <h3 class="text-sm font-medium text-neutral-dark">Install PCFG Insurance</h3>
          <p class="mt-1 text-sm text-neutral-dark">Add to your home screen for faster access and a better experience.</p>
          <div class="mt-2 flex space-x-2">
            <button id="install-pwa" class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md text-white bg-primary hover:bg-primary-dark focus:outline-none">
              Install
            </button>
            <button id="dismiss-pwa" class="inline-flex items-center px-3 py-1.5 border border-neutral-300 text-xs font-medium rounded-md text-neutral-dark bg-white hover:bg-neutral-light focus:outline-none">
              Not now
            </button>
