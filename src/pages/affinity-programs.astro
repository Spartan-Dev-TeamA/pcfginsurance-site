---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import LocalSEO from '../components/LocalSEO.astro';

const breadcrumbs = [
  { label: 'Home', url: '/' },
  { label: 'Affinity Programs', url: '/affinity-programs' }
];

const affinityGroups = [
  {
    title: 'Professional Associations',
    description: 'Tailored insurance solutions for members of professional organizations, trade associations, and industry groups.',
    icon: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    benefits: [
      'Group purchasing power for better rates',
      'Industry-specific coverage options',
      'Dedicated account management',
      'Member-exclusive discounts'
    ]
  },
  {
    title: 'Alumni & Educational Groups',
    description: 'Comprehensive insurance programs for college alumni associations, educational institutions, and student organizations.',
    icon: 'M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z',
    benefits: [
      'Life and health insurance options',
      'Auto and home insurance packages',
      'Student-friendly payment plans',
      'Alumni network pricing advantages'
    ]
  },
  {
    title: 'Employee Groups & Unions',
    description: 'Specialized group insurance programs for union members, employee associations, and workforce collectives.',
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
    benefits: [
      'Group life and disability coverage',
      'Supplemental health benefits',
      'Voluntary benefit programs',
      'Payroll deduction options'
    ]
  },
  {
    title: 'Credit Union & Financial Groups',
    description: 'Insurance solutions designed for credit union members and financial institution affinity groups.',
    icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z',
    benefits: [
      'Auto and home insurance programs',
      'Personal umbrella coverage',
      'Identity theft protection',
      'Member loyalty rewards'
    ]
  },
  {
    title: 'Membership Organizations',
    description: 'Custom insurance programs for social clubs, civic organizations, and membership-based groups.',
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
    benefits: [
      'Property and casualty insurance',
      'Event liability coverage',
      'Directors and officers insurance',
      'Flexible coverage terms'
    ]
  },
  {
    title: 'Chamber of Commerce Members',
    description: 'Business insurance solutions for local chamber members and small business communities.',
    icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9',
    benefits: [
      'Business owners policy (BOP)',
      'Commercial general liability',
      'Workers compensation',
      'Small business packages'
    ]
  }
];

const coverageOptions = [
  {
    category: 'Life & Health Products',
    offerings: [
      'Group Life Insurance',
      'Individual Life Insurance',
      'Disability Income Insurance',
      'Critical Illness Coverage',
      'Long-Term Care Insurance',
      'Health Savings Accounts (HSA)',
      'Supplemental Health Benefits'
    ]
  },
  {
    category: 'Personal Lines Insurance',
    offerings: [
      'Auto Insurance',
      'Homeowners Insurance',
      'Renters Insurance',
      'Umbrella Liability',
      'Boat & Recreational Vehicle',
      'Valuable Items Coverage',
      'Identity Theft Protection'
    ]
  },
  {
    category: 'Business Insurance',
    offerings: [
      'Business Owners Policy (BOP)',
      'General Liability Insurance',
      'Commercial Auto Insurance',
      'Workers Compensation',
      'Professional Liability',
      'Cyber Liability Insurance',
      'Commercial Property'
    ]
  },
  {
    category: 'Group Benefits',
    offerings: [
      'Group Health Insurance',
      'Group Dental & Vision',
      'Group Life & AD&D',
      'Short & Long-Term Disability',
      'Voluntary Benefits',
      'Flexible Spending Accounts',
      'Employee Assistance Programs'
    ]
  }
];

const whyChoose = [
  {
    title: 'Competitive Group Rates',
    description: 'Leverage the collective buying power of your organization for preferred pricing and enhanced coverage options.'
  },
  {
    title: 'Customized Solutions',
    description: 'Programs designed specifically for your group\'s unique needs, industry requirements, and member demographics.'
  },
  {
    title: 'Simplified Administration',
    description: 'Streamlined enrollment, billing, and claims processes with dedicated support for program administrators.'
  },
  {
    title: 'Member Education',
    description: 'Comprehensive resources, webinars, and consultations to help members understand and maximize their benefits.'
  },
  {
    title: 'Nationwide Coverage',
    description: 'Licensed in 15 states with access to top-rated carriers, ensuring consistent service wherever members are located.'
  },
  {
    title: 'Dedicated Service Team',
    description: 'Experienced account managers who understand your organization and provide personalized support to all members.'
  }
];
---

<Layout
  title="Affinity Group Insurance Programs | PCFG Insurance Services"
  description="Specialized insurance programs for professional associations, alumni groups, unions, and membership organizations. Competitive group rates for life, health, personal, and business insurance across 15 states."
  ogImage="https://images.pexels.com/photos/3184292/pexels-photo-3184292.jpeg?auto=compress&cs=tinysrgb&w=1200&h=630"
  ogType="article"
>
  <LocalSEO pageName="Affinity Programs" />
  <Header />

  <Breadcrumbs items={breadcrumbs} />

  <!-- Hero Section -->
  <section class="relative py-16 md:py-24 overflow-hidden" style="background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);">
    <div class="absolute inset-0 opacity-10">
      <img
        src="https://images.pexels.com/photos/3184292/pexels-photo-3184292.jpeg?auto=compress&cs=tinysrgb&w=1920"
        alt="Group of professionals"
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 text-neutral-dark">
          Affinity Group Insurance Programs
        </h1>
        <p class="text-xl md:text-2xl text-neutral-medium mb-8">
          Specialized insurance solutions designed exclusively for associations, organizations, and membership groups
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="/contact" variant="primary" size="lg" text="Start a Program" />
          <Button href="#coverage" variant="secondary" size="lg" text="Explore Coverage" />
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 text-neutral-dark">
            Strength in Numbers
          </h2>
          <p class="text-lg text-neutral-medium mb-6">
            At PCFG Insurance Services, we understand that organizations and associations have unique insurance needs. Our affinity group programs harness the collective purchasing power of your members to deliver competitive rates, comprehensive coverage, and exceptional service.
          </p>
          <p class="text-lg text-neutral-medium mb-6">
            Whether you represent a professional association, alumni network, employee group, or membership organization, we'll design a customized insurance program that provides real value to your members while simplifying administration for your organization.
          </p>
          <div class="bg-primary-50 border-l-4 border-primary p-6 rounded-r-lg">
            <p class="text-neutral-dark font-semibold mb-2">Licensed in 15 States</p>
            <p class="text-neutral-medium">Serving organizations and their members across NY, PA, FL, TX, CA, and more.</p>
          </div>
        </div>
        <div>
          <img
            src="https://images.pexels.com/photos/3184360/pexels-photo-3184360.jpeg?auto=compress&cs=tinysrgb&w=800"
            alt="Business professionals collaborating"
            class="rounded-lg shadow-lg w-full h-auto"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Affinity Groups We Serve -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-neutral-dark">
          Affinity Groups We Serve
        </h2>
        <p class="text-lg text-neutral-medium max-w-3xl mx-auto">
          We partner with diverse organizations to create tailored insurance programs that meet the specific needs of their members
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {affinityGroups.map((group) => (
          <div class="bg-white rounded-lg shadow-md p-8 hover:shadow-xl transition-shadow">
            <div class="flex items-center justify-center w-16 h-16 bg-primary-100 rounded-lg mb-6">
              <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={group.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-neutral-dark">{group.title}</h3>
            <p class="text-neutral-medium mb-6">{group.description}</p>
            <ul class="space-y-2">
              {group.benefits.map((benefit) => (
                <li class="flex items-start text-sm text-neutral-medium">
                  <svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {benefit}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Coverage Options -->
  <section id="coverage" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-neutral-dark">
          Comprehensive Coverage Options
        </h2>
        <p class="text-lg text-neutral-medium max-w-3xl mx-auto">
          Our affinity programs offer a full spectrum of insurance products to protect your members' personal and professional lives
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {coverageOptions.map((option) => (
          <div class="bg-gradient-to-br from-gray-50 to-white border border-gray-200 rounded-lg p-8">
            <h3 class="text-2xl font-bold mb-6 text-neutral-dark border-b-2 border-primary pb-3">
              {option.category}
            </h3>
            <ul class="space-y-3">
              {option.offerings.map((offering) => (
                <li class="flex items-center text-neutral-medium">
                  <svg class="w-5 h-5 text-primary mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  {offering}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Our Affinity Programs -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-neutral-dark">
          Why Choose PCFG Affinity Programs
        </h2>
        <p class="text-lg text-neutral-medium max-w-3xl mx-auto">
          We go beyond standard insurance offerings to deliver exceptional value and service to your organization and its members
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {whyChoose.map((reason) => (
          <div class="bg-white rounded-lg p-8 shadow-md hover:shadow-lg transition-shadow">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 bg-primary rounded-full flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-xl font-bold text-neutral-dark">{reason.title}</h3>
            </div>
            <p class="text-neutral-medium leading-relaxed">{reason.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-neutral-dark">
          How Our Affinity Programs Work
        </h2>
        <p class="text-lg text-neutral-medium max-w-3xl mx-auto">
          A simple, streamlined process from program design to ongoing member support
        </p>
      </div>

      <div class="grid md:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-20 h-20 bg-primary rounded-full flex items-center justify-center mx-auto mb-6 text-white text-2xl font-bold">
            1
          </div>
          <h3 class="text-xl font-bold mb-3 text-neutral-dark">Discovery</h3>
          <p class="text-neutral-medium">
            We learn about your organization, member demographics, and insurance needs
          </p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 bg-primary rounded-full flex items-center justify-center mx-auto mb-6 text-white text-2xl font-bold">
            2
          </div>
          <h3 class="text-xl font-bold mb-3 text-neutral-dark">Design</h3>
          <p class="text-neutral-medium">
            Custom program creation with competitive rates and comprehensive coverage options
          </p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 bg-primary rounded-full flex items-center justify-center mx-auto mb-6 text-white text-2xl font-bold">
            3
          </div>
          <h3 class="text-xl font-bold mb-3 text-neutral-dark">Launch</h3>
          <p class="text-neutral-medium">
            Member communication, enrollment support, and marketing materials provided
          </p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 bg-primary rounded-full flex items-center justify-center mx-auto mb-6 text-white text-2xl font-bold">
            4
          </div>
          <h3 class="text-xl font-bold mb-3 text-neutral-dark">Support</h3>
          <p class="text-neutral-medium">
            Ongoing administration, member service, and program optimization
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Statistics Section -->
  <section class="py-16 bg-primary text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-5xl font-bold mb-2">15+</div>
          <div class="text-xl opacity-90">States Licensed</div>
        </div>
        <div>
          <div class="text-5xl font-bold mb-2">20+</div>
          <div class="text-xl opacity-90">Years Experience</div>
        </div>
        <div>
          <div class="text-5xl font-bold mb-2">50+</div>
          <div class="text-xl opacity-90">Carrier Partners</div>
        </div>
        <div>
          <div class="text-5xl font-bold mb-2">100%</div>
          <div class="text-xl opacity-90">Dedicated Service</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-gradient-to-r from-primary-dark to-primary">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6 text-white">
        Ready to Create a Program for Your Organization?
      </h2>
      <p class="text-xl text-white opacity-90 mb-8">
        Let's discuss how we can design an affinity insurance program that delivers exceptional value to your members
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/contact" variant="secondary" size="lg" text="Contact Us Today" />
        <a
          href="tel:+18777177234"
          class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white border-2 border-white rounded-lg hover:bg-white hover:text-primary transition-all"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          (877) 717-7234
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
