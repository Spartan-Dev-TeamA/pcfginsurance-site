---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Industries We Serve - PCFG Insurance Services" description="PCFG Insurance Services provides specialized insurance solutions for construction, HVAC, transportation, agriculture, healthcare, and small businesses across 15 states.">
  <Header />
  
  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-navy-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Industries We Serve</h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Specialized insurance solutions tailored to the unique risks and requirements of your industry across 15 states.
        </p>
      </div>
    </div>
  </section>
  
  <!-- Licensed States Banner -->
  <section class="py-12 bg-navy-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-xl font-bold text-white mb-4">Serving Industries Across Our Licensed States:</h2>
        <div class="flex flex-wrap justify-center gap-3">
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">AL</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">AZ</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">FL</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">GA</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">IN</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">MD</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">ME</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">NJ</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">NY</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">NC</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">OH</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">PA</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">TN</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">TX</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">VA</span>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Industries Grid -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        
        <!-- Construction -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-16 h-16 bg-navy-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Construction</h3>
          <p class="text-gray-600 mb-6">
            Comprehensive coverage for general contractors, subcontractors, and specialty trades. We understand the unique risks of the construction industry across all our licensed states.
          </p>
          <div class="mb-6">
            <h4 class="font-semibold text-gray-900 mb-2">Specialized Coverage:</h4>
            <ul class="text-sm text-gray-600 space-y-1">
              <li>• Workers' compensation for high-risk trades</li>
              <li>• General liability with completed operations</li>
              <li>• Commercial auto for work vehicles</li>
              <li>• Tools and equipment coverage</li>
              <li>• Surety bonds</li>
            </ul>
          </div>
          <a href="/contact" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-2 rounded-md font-medium transition-colors duration-200">
            Get Quote
          </a>
        </div>
        
        <!-- HVAC -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-16 h-16 bg-navy-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">HVAC</h3>
          <p class="text-gray-600 mb-6">
            Tailored insurance solutions for heating, ventilation, and air conditioning contractors and service companies.
          </p>
          <div class="mb-6">
            <h4 class="font-semibold text-gray-900 mb-2">Key Protections:</h4>
            <ul class="text-sm text-gray-600 space-y-1">
              <li>• Installation errors & omissions</li>
              <li>• Equipment breakdown coverage</li>
              <li>• Commercial vehicle insurance</li>
              <li>• Professional liability</li>
              <li>• Pollution liability</li>
            </ul>
          </div>
          <a href="/contact" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-2 rounded-md font-medium transition-colors duration-200">
            Get Quote
          </a>
        </div>
        
        <!-- Transportation -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-16 h-16 bg-navy-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a4 4 0 118 0v4m-4 8a2 2 0 11-4 0 2 2 0 014 0zm6 0a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Transportation</h3>
          <p class="text-gray-600 mb-6">
            Complete coverage solutions for trucking companies, delivery services, and transportation businesses of all sizes.
          </p>
          <div class="mb-6">
            <h4 class="font-semibold text-gray-900 mb-2">Fleet Protection:</h4>
            <ul class="text-sm text-gray-600 space-y-1">
              <li>• Commercial auto liability</li>
              <li>• Cargo insurance</li>
              <li>• Motor truck cargo coverage</li>
              <li>• Non-trucking liability</li>
              <li>• Occupational accident insurance</li>
            </ul>
          </div>
          <a href="/contact" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-2 rounded-md font-medium transition-colors duration-200">
            Get Quote
          </a>
        </div>
        
        <!-- Agriculture -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-16 h-16 bg-navy-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Agriculture</h3>
          <p class="text-gray-600 mb-6">
            Specialized insurance for farms, agricultural operations, and agribusiness throughout our licensed states.
          </p>
          <div class="mb-6">
            <h4 class="font-semibold text-gray-900 mb-2">Farm Coverage:</h4>
            <ul class="text-sm text-gray-600 space-y-1">
              <li>• Farm property insurance</li>
              <li>• Livestock coverage</li>
              <li>• Equipment and machinery</li>
              <li>• Crop insurance</li>
              <li>• Farm liability protection</li>
            </ul>
          </div>
          <a href="/contact" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-2 rounded-md font-medium transition-colors duration-200">
            Get Quote
          </a>
        </div>
        
        <!-- Healthcare -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-16 h-16 bg-navy-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Healthcare</h3>
          <p class="text-gray-600 mb-6">
            Comprehensive coverage for medical practices, healthcare facilities, and healthcare professionals.
          </p>
          <div class="mb-6">
            <h4 class="font-semibold text-gray-900 mb-2">Medical Coverage:</h4>
            <ul class="text-sm text-gray-600 space-y-1">
              <li>• Medical malpractice insurance</li>
              <li>• HIPAA violation coverage</li>
              <li>• Cyber liability for patient data</li>
              <li>• Employment practices liability</li>
              <li>• Business interruption</li>
            </ul>
          </div>
          <a href="/contact" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-2 rounded-md font-medium transition-colors duration-200">
            Get Quote
          </a>
        </div>
        
        <!-- Small Business -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-16 h-16 bg-navy-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Small Business</h3>
          <p class="text-gray-600 mb-6">
            Affordable, comprehensive insurance packages designed specifically for small business owners and entrepreneurs.
          </p>
          <div class="mb-6">
            <h4 class="font-semibold text-gray-900 mb-2">Business Essentials:</h4>
            <ul class="text-sm text-gray-600 space-y-1">
              <li>• Business owner's policy (BOP)</li>
              <li>• General liability coverage</li>
              <li>• Commercial property insurance</li>
              <li>• Cyber liability protection</li>
              <li>• Key person life insurance</li>
            </ul>
          </div>
          <a href="/contact" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-2 rounded-md font-medium transition-colors duration-200">
            Get Quote
          </a>
        </div>
        
        <!-- Manufacturing -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-16 h-16 bg-navy-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Manufacturing</h3>
          <p class="text-gray-600 mb-6">
            Specialized coverage for manufacturers, including product liability, equipment breakdown, and supply chain protection.
          </p>
          <div class="mb-6">
            <h4 class="font-semibold text-gray-900 mb-2">Manufacturing Risks:</h4>
            <ul class="text-sm text-gray-600 space-y-1">
              <li>• Product liability insurance</li>
              <li>• Equipment breakdown coverage</li>
              <li>• Business interruption</li>
              <li>• Environmental liability</li>
              <li>• Supply chain protection</li>
            </ul>
          </div>
          <a href="/contact" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-2 rounded-md font-medium transition-colors duration-200">
            Get Quote
          </a>
        </div>
        
        <!-- Retail -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-16 h-16 bg-navy-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l-1 12H6L5 9z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Retail</h3>
          <p class="text-gray-600 mb-6">
            Complete protection for retail businesses, from small shops to large retail chains, including inventory and customer liability.
          </p>
          <div class="mb-6">
            <h4 class="font-semibold text-gray-900 mb-2">Retail Protection:</h4>
            <ul class="text-sm text-gray-600 space-y-1">
              <li>• General liability coverage</li>
              <li>• Product liability insurance</li>
              <li>• Inventory protection</li>
              <li>• Crime and theft coverage</li>
              <li>• Employment practices liability</li>
            </ul>
          </div>
          <a href="/contact" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-2 rounded-md font-medium transition-colors duration-200">
            Get Quote
          </a>
        </div>
        
        <!-- Professional Services -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-16 h-16 bg-navy-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Professional Services</h3>
          <p class="text-gray-600 mb-6">
            Tailored coverage for consultants, accountants, lawyers, architects, engineers, and other professional service providers.
          </p>
          <div class="mb-6">
            <h4 class="font-semibold text-gray-900 mb-2">Professional Risks:</h4>
            <ul class="text-sm text-gray-600 space-y-1">
              <li>• Professional liability (E&O)</li>
              <li>• Cyber liability coverage</li>
              <li>• Employment practices liability</li>
              <li>• Directors & officers insurance</li>
              <li>• Fiduciary liability</li>
            </ul>
          </div>
          <a href="/contact" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-2 rounded-md font-medium transition-colors duration-200">
            Get Quote
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Industry Expertise Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Why Industry Expertise Matters</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Every industry faces unique risks and challenges. Our specialized knowledge helps us provide the right coverage for your specific business needs across all our licensed states.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Risk Assessment</h3>
          <p class="text-gray-600">We understand the specific risks your industry faces and can identify potential exposures you might miss.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Cost Optimization</h3>
          <p class="text-gray-600">Industry-specific knowledge helps us find the most cost-effective coverage options for your business.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Claims Support</h3>
          <p class="text-gray-600">When claims occur, our industry expertise helps ensure faster resolution and better outcomes.</p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- CTA Section -->
  <section class="py-20 bg-navy-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Don't See Your Industry?</h2>
      <p class="text-xl text-navy-100 mb-8 max-w-2xl mx-auto">
        We work with businesses across many industries in all our licensed states. Contact us to discuss your specific insurance needs and how we can help protect your business.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-navy-600 hover:bg-gray-100 px-8 py-3 rounded-md font-semibold transition-colors duration-200">
          Discuss Your Needs
        </a>
        <a href="tel:877-717-7234" class="border-2 border-white text-white hover:bg-white hover:text-navy-600 px-8 py-3 rounded-md font-semibold transition-colors duration-200">
          Call (877) 717-7234
        </a>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>