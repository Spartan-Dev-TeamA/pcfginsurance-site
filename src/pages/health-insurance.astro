---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Health Insurance - PCFG Insurance Services" description="Comprehensive health insurance solutions including individual coverage, MVP plans, MEC plans, and health savings accounts for businesses and individuals.">
  <Header />
  
  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-navy-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Health Insurance</h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Comprehensive health insurance solutions for businesses and individuals. From traditional individual plans to innovative cost-saving options, we help you find the right coverage.
        </p>
      </div>
    </div>
  </section>
  
  <!-- Health Insurance Types -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Individual Health Insurance -->
      <div id="individual-health" class="mb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="bg-gray-100 p-8 rounded-lg order-2 lg:order-1">
            <div class="w-16 h-16 bg-navy-600 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
            </div>
            <h4 class="text-xl font-semibold text-gray-900 mb-4">Individual Plan Features</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• ACA-compliant coverage</li>
              <li>• Essential health benefits included</li>
              <li>• No pre-existing condition exclusions</li>
              <li>• Preventive care at no cost</li>
              <li>• Prescription drug coverage</li>
              <li>• Mental health and substance abuse coverage</li>
            </ul>
            <div class="mt-6 p-4 bg-white rounded border-l-4 border-navy-600">
              <p class="text-sm text-gray-600">
                <strong>Open Enrollment:</strong> Individual plans are typically available during open enrollment periods or qualifying life events.
              </p>
            </div>
          </div>
          <div class="order-1 lg:order-2">
            <h2 class="text-3xl font-bold text-gray-900 mb-6">Individual Health Insurance</h2>
            <p class="text-lg text-gray-600 mb-6">
              Personal health insurance coverage for individuals and families who don't have access to employer-sponsored plans or need additional coverage options.
            </p>
            <div class="mb-6">
              <h3 class="text-xl font-semibold text-gray-900 mb-3">Coverage Levels:</h3>
              <div class="space-y-4">
                <div class="border-l-4 border-navy-600 pl-4">
                  <h4 class="font-semibold text-gray-900">Bronze Plans</h4>
                  <p class="text-gray-600">Lower premiums, higher deductibles (60% actuarial value)</p>
                </div>
                <div class="border-l-4 border-navy-600 pl-4">
                  <h4 class="font-semibold text-gray-900">Silver Plans</h4>
                  <p class="text-gray-600">Moderate premiums and deductibles (70% actuarial value)</p>
                </div>
                <div class="border-l-4 border-navy-600 pl-4">
                  <h4 class="font-semibold text-gray-900">Gold Plans</h4>
                  <p class="text-gray-600">Higher premiums, lower deductibles (80% actuarial value)</p>
                </div>
                <div class="border-l-4 border-navy-600 pl-4">
                  <h4 class="font-semibold text-gray-900">Platinum Plans</h4>
                  <p class="text-gray-600">Highest premiums, lowest deductibles (90% actuarial value)</p>
                </div>
              </div>
            </div>
            <a href="/contact" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200">
              Get Individual Health Quote
            </a>
          </div>
        </div>
      </div>
      
      <!-- MVP and MEC Plans -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-20">
        
        <!-- MVP Plans -->
        <div id="mvp-plans" class="bg-white p-8 rounded-lg shadow-lg">
          <div class="w-16 h-16 bg-green-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Minimum Value Plans (MVP)</h3>
          <p class="text-gray-600 mb-6">
            Cost-effective health plans that meet ACA minimum value requirements while providing essential coverage at lower premiums.
          </p>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">MVP Features:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Meets 60% minimum actuarial value</li>
              <li>• Lower premium costs</li>
              <li>• Essential health benefits included</li>
              <li>• Preventive care coverage</li>
              <li>• Prescription drug benefits</li>
              <li>• ACA employer mandate compliance</li>
            </ul>
          </div>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">Ideal For:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Cost-conscious employers</li>
              <li>• Businesses with younger workforce</li>
              <li>• Companies seeking ACA compliance</li>
              <li>• Organizations with tight budgets</li>
            </ul>
          </div>
          
          <a href="/contact" class="bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200 w-full block text-center">
            Learn About MVP Plans
          </a>
        </div>
        
        <!-- MEC Plans -->
        <div id="mec-plans" class="bg-white p-8 rounded-lg shadow-lg">
          <div class="w-16 h-16 bg-blue-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Minimum Essential Coverage (MEC)</h3>
          <p class="text-gray-600 mb-6">
            Basic health coverage that satisfies the ACA individual mandate requirement, providing essential protection at the most affordable rates.
          </p>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">MEC Features:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Satisfies individual mandate</li>
              <li>• Lowest cost option</li>
              <li>• Preventive care included</li>
              <li>• Basic medical services</li>
              <li>• Limited benefit structure</li>
              <li>• No penalty for employees</li>
            </ul>
          </div>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">Best For:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Large employers (50+ employees)</li>
              <li>• High-turnover industries</li>
              <li>• Part-time workforce</li>
              <li>• Minimum compliance strategy</li>
            </ul>
          </div>
          
          <a href="/contact" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200 w-full block text-center">
            Learn About MEC Plans
          </a>
        </div>
      </div>
      
      <!-- Health Savings Accounts -->
      <div id="hsa" class="mb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl font-bold text-gray-900 mb-6">Health Savings Accounts (HSA)</h2>
            <p class="text-lg text-gray-600 mb-6">
              Triple tax-advantaged accounts paired with high-deductible health plans. Save money on healthcare costs while building long-term savings for medical expenses.
            </p>
            <div class="mb-6">
              <h3 class="text-xl font-semibold text-gray-900 mb-3">Triple Tax Advantage:</h3>
              <div class="space-y-4">
                <div class="border-l-4 border-navy-600 pl-4">
                  <h4 class="font-semibold text-gray-900">Tax-Deductible Contributions</h4>
                  <p class="text-gray-600">Reduce your taxable income with pre-tax contributions</p>
                </div>
                <div class="border-l-4 border-navy-600 pl-4">
                  <h4 class="font-semibold text-gray-900">Tax-Free Growth</h4>
                  <p class="text-gray-600">Earnings and interest grow without tax consequences</p>
                </div>
                <div class="border-l-4 border-navy-600 pl-4">
                  <h4 class="font-semibold text-gray-900">Tax-Free Withdrawals</h4>
                  <p class="text-gray-600">No taxes on qualified medical expense withdrawals</p>
                </div>
              </div>
            </div>
            <a href="/contact" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200">
              Learn About HSAs
            </a>
          </div>
          <div class="bg-gray-100 p-8 rounded-lg">
            <div class="w-16 h-16 bg-navy-600 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
              </svg>
            </div>
            <h4 class="text-xl font-semibold text-gray-900 mb-4">2024 HSA Limits</h4>
            <div class="space-y-4">
              <div class="bg-white p-4 rounded border-l-4 border-navy-600">
                <h5 class="font-semibold text-gray-900">Individual Coverage</h5>
                <p class="text-gray-600">Maximum contribution: $4,150</p>
                <p class="text-gray-600">Minimum deductible: $1,600</p>
              </div>
              <div class="bg-white p-4 rounded border-l-4 border-navy-600">
                <h5 class="font-semibold text-gray-900">Family Coverage</h5>
                <p class="text-gray-600">Maximum contribution: $8,300</p>
                <p class="text-gray-600">Minimum deductible: $3,200</p>
              </div>
              <div class="bg-white p-4 rounded border-l-4 border-navy-600">
                <h5 class="font-semibold text-gray-900">Catch-Up (55+)</h5>
                <p class="text-gray-600">Additional $1,000 contribution</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Health Plan Comparison -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Compare Health Plan Options</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Understanding the differences between plan types helps you choose the right coverage for your needs and budget.
        </p>
      </div>
      
      <div class="overflow-x-auto">
        <table class="w-full bg-white rounded-lg shadow-lg overflow-hidden">
          <thead class="bg-navy-600 text-white">
            <tr>
              <th class="px-6 py-4 text-left">Feature</th>
              <th class="px-6 py-4 text-center">HMO</th>
              <th class="px-6 py-4 text-center">PPO</th>
              <th class="px-6 py-4 text-center">HDHP/HSA</th>
              <th class="px-6 py-4 text-center">MVP</th>
              <th class="px-6 py-4 text-center">MEC</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <tr>
              <td class="px-6 py-4 font-medium text-gray-900">Premium Cost</td>
              <td class="px-6 py-4 text-center text-green-600">Low</td>
              <td class="px-6 py-4 text-center text-red-600">High</td>
              <td class="px-6 py-4 text-center text-yellow-600">Medium</td>
              <td class="px-6 py-4 text-center text-green-600">Low</td>
              <td class="px-6 py-4 text-center text-green-600">Lowest</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Deductible</td>
              <td class="px-6 py-4 text-center text-green-600">Low</td>
              <td class="px-6 py-4 text-center text-yellow-600">Medium</td>
              <td class="px-6 py-4 text-center text-red-600">High</td>
              <td class="px-6 py-4 text-center text-red-600">High</td>
              <td class="px-6 py-4 text-center text-red-600">High</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-medium text-gray-900">Provider Network</td>
              <td class="px-6 py-4 text-center text-red-600">Restricted</td>
              <td class="px-6 py-4 text-center text-green-600">Flexible</td>
              <td class="px-6 py-4 text-center text-yellow-600">Varies</td>
              <td class="px-6 py-4 text-center text-yellow-600">Varies</td>
              <td class="px-6 py-4 text-center text-red-600">Limited</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Referrals Required</td>
              <td class="px-6 py-4 text-center">Yes</td>
              <td class="px-6 py-4 text-center">No</td>
              <td class="px-6 py-4 text-center">Varies</td>
              <td class="px-6 py-4 text-center">Varies</td>
              <td class="px-6 py-4 text-center">Varies</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-medium text-gray-900">HSA Eligible</td>
              <td class="px-6 py-4 text-center">No</td>
              <td class="px-6 py-4 text-center">No</td>
              <td class="px-6 py-4 text-center text-green-600">Yes</td>
              <td class="px-6 py-4 text-center">No</td>
              <td class="px-6 py-4 text-center">No</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">Best For</td>
              <td class="px-6 py-4 text-center text-sm">Budget-conscious, routine care</td>
              <td class="px-6 py-4 text-center text-sm">Flexibility, specialists</td>
              <td class="px-6 py-4 text-center text-sm">Healthy, tax savings</td>
              <td class="px-6 py-4 text-center text-sm">ACA compliance</td>
              <td class="px-6 py-4 text-center text-sm">Minimum coverage</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>
  
  <!-- CTA Section -->
  <section class="py-20 bg-navy-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Find the Right Health Insurance Solution</h2>
      <p class="text-xl text-navy-100 mb-8 max-w-2xl mx-auto">
        Whether you need individual plans for your family, our health insurance experts will help you navigate your options and find the best coverage.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-navy-600 hover:bg-gray-100 px-8 py-3 rounded-md font-semibold transition-colors duration-200">
          Get Health Insurance Quote
        </a>
        <a href="tel:877-717-7234" class="border-2 border-white text-white hover:bg-white hover:text-navy-600 px-8 py-3 rounded-md font-semibold transition-colors duration-200">
          Call (877) 717-7234
        </a>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>