---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="PCFG Insurance Blog" description="Insurance insights, tips, and news for business owners in New York and beyond.">
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">PCFG Insurance Blog</h1>
        <p class="text-xl text-gray-600">
          Insights for protecting your business and your team.
        </p>
      </div>

      <div class="space-y-8">
        {posts.map(post => (
          <a href={`/blog/${post.slug}/`} class="block bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
            <h2 class="text-2xl font-bold text-gray-900 mb-2">{post.data.title}</h2>
            <p class="text-gray-500 mb-4">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
            <p class="text-gray-600 mb-4">{post.data.description}</p>
            <span class="font-semibold text-navy-600 hover:underline">Read More &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
