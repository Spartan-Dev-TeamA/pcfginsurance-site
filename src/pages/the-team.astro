---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Our Team | PCFG Insurance Services" description="Meet the dedicated professionals at PCFG Insurance Services who are committed to protecting what matters most to your business and family across 15 states.">
  <Header />
  
  <!-- This page is temporarily hidden while being updated -->
  <div class="py-20 bg-neutral-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-neutral-dark mb-6 font-heading">Coming Soon</h1>
      <p class="text-xl text-neutral-dark max-w-3xl mx-auto mb-8">
        We're currently updating our team page. Please check back soon to meet the dedicated professionals at PCFG Insurance Services.
      </p>
      <a href="/contact" class="bg-primary hover:bg-primary-dark text-white px-8 py-3 rounded-lg font-semibold transition-colors duration-200 inline-block">
        Contact Us
      </a>
    </div>
  </div>
  
  <Footer />
</Layout>