---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Life Insurance Needs Analysis - PCFG Insurance Services" description="Complete our comprehensive life insurance needs analysis survey to determine the right coverage amount for your family's financial security and protection needs." ogImage="https://images.pexels.com/photos/1153213/pexels-photo-1153213.jpeg?auto=compress&cs=tinysrgb&w=1200&h=630" ogType="website">
  <Header />

  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-navy-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Life Insurance Needs Analysis</h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Determine the right amount of life insurance coverage for your family with our comprehensive needs analysis survey. Get personalized recommendations based on your unique situation.
        </p>
      </div>
    </div>
  </section>

  <!-- Why Complete a Needs Analysis -->
  <section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <div class="text-center">
          <div class="w-16 h-16 bg-navy-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Accurate Coverage</h3>
          <p class="text-gray-600">Ensure you have the right amount of coverage - not too much, not too little.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-navy-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Cost Effective</h3>
          <p class="text-gray-600">Avoid overpaying for unnecessary coverage or being underinsured.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-navy-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Peace of Mind</h3>
          <p class="text-gray-600">Know your family will be financially protected no matter what happens.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Needs Analysis Survey Form -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-lg shadow-xl p-8">
        <div class="mb-8">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Complete Your Needs Analysis</h2>
          <p class="text-lg text-gray-600">
            Answer the questions below to help us calculate the appropriate life insurance coverage for your situation. This typically takes 5-10 minutes to complete.
          </p>
        </div>

        <div style="min-height: 800px;">
          <iframe
            src="https://link.spartan-crm.com/widget/survey/Eaww6KHgWmeUJb4jAleC"
            style="border:none;width:100%;min-height:800px;"
            scrolling="no"
            id="Eaww6KHgWmeUJb4jAleC"
            title="Life Insurance Needs Analysis Survey"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Consider -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">What We Consider in Your Analysis</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Our comprehensive needs analysis takes multiple factors into account to provide an accurate recommendation.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-gray-50 p-6 rounded-lg">
          <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Income Replacement</h3>
          <p class="text-gray-600">
            Calculate how much income your family needs replaced and for how long to maintain their standard of living.
          </p>
        </div>

        <div class="bg-gray-50 p-6 rounded-lg">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Debt Obligations</h3>
          <p class="text-gray-600">
            Include outstanding debts like mortgages, car loans, and credit cards to ensure they're covered.
          </p>
        </div>

        <div class="bg-gray-50 p-6 rounded-lg">
          <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Education Costs</h3>
          <p class="text-gray-600">
            Factor in future college expenses for your children to ensure their educational goals are funded.
          </p>
        </div>

        <div class="bg-gray-50 p-6 rounded-lg">
          <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Final Expenses</h3>
          <p class="text-gray-600">
            Cover funeral and burial costs, medical bills, and other final expenses to protect your family.
          </p>
        </div>

        <div class="bg-gray-50 p-6 rounded-lg">
          <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Emergency Fund</h3>
          <p class="text-gray-600">
            Include funds for unexpected expenses and provide a financial cushion during the transition period.
          </p>
        </div>

        <div class="bg-gray-50 p-6 rounded-lg">
          <div class="w-12 h-12 bg-indigo-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Existing Coverage</h3>
          <p class="text-gray-600">
            Account for any current life insurance policies, employer coverage, and other assets to avoid over-insuring.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- After Your Analysis -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">What Happens After Your Analysis?</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-white">1</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Review Your Results</h3>
          <p class="text-gray-600">We'll analyze your responses and calculate your recommended coverage amount.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-white">2</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Personalized Consultation</h3>
          <p class="text-gray-600">An experienced agent will contact you to discuss your needs and answer questions.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-white">3</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Compare Options</h3>
          <p class="text-gray-600">We'll present multiple policy options from top-rated carriers for your situation.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-white">4</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Get Protected</h3>
          <p class="text-gray-600">Choose the right policy and complete the application to secure your family's future.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-navy-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Have Questions About Life Insurance?</h2>
      <p class="text-xl text-navy-100 mb-8 max-w-2xl mx-auto">
        Our experienced agents are here to help you understand your coverage needs and find the right policy for your family.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-navy-600 hover:bg-gray-100 px-8 py-3 rounded-md font-semibold transition-colors duration-200">
          Contact Us
        </a>
        <a href="tel:877-717-7234" class="border-2 border-white text-white hover:bg-white hover:text-navy-600 px-8 py-3 rounded-md font-semibold transition-colors duration-200">
          Call (877) 717-7234
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script src="https://link.spartan-crm.com/js/form_embed.js"></script>
