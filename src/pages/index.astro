---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import QuoteForm from '../components/QuoteForm.astro';
---

<Layout title="PCFG Insurance Services - Business & Personal Insurance Across 15 States" description="Professional insurance services for businesses and families across 15 states. Workers' compensation, commercial auto, general liability, and personal lines coverage. Get your free quote today.">
  <Header />
  
  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-primary-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="mb-6">
            <span class="inline-block bg-primary-100 text-primary-800 text-sm font-medium px-3 py-1 rounded-full">
              Veteran-Owned & Operated
            </span>
          </div>
          <h1 class="text-4xl md:text-6xl font-bold text-neutral-dark mb-6 font-heading">
            Protecting What Matters Most
          </h1>
          <p class="text-xl text-neutral-dark mb-8 leading-relaxed">
            Professional insurance services for businesses and families across 15 states. From workers' compensation to personal auto and home insurance, we've got you covered with competitive rates and exceptional service.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a href="#quote-form" class="bg-primary hover:bg-primary-dark text-white px-8 py-4 rounded-lg font-semibold text-center transition-colors duration-200 shadow-lg">
              Get Free Quote
            </a>
            <a href="tel:877-717-7234" class="border-2 border-primary text-primary hover:bg-primary hover:text-white px-8 py-4 rounded-lg font-semibold text-center transition-colors duration-200">
              Call (877) 717-7234
            </a>
          </div>
          
          <!-- Trust Indicators -->
          <div class="flex items-center space-x-6 text-sm text-neutral-dark">
            <div class="flex items-center">
              <svg class="w-5 h-5 text-primary mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Licensed in 15 States
            </div>
            <div class="flex items-center">
              <svg class="w-5 h-5 text-primary mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
              24/7 Claims Support
            </div>
            <div class="flex items-center">
              <svg class="w-5 h-5 text-primary mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
              </svg>
              Competitive Rates
            </div>
          </div>
        </div>
        
        <!-- Quote Form -->
        <div id="quote-form">
          <QuoteForm />
        </div>
      </div>
    </div>
  </section>
  
  <!-- Services Preview -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-neutral-dark mb-4 font-heading">Insurance Solutions for Every Need</h2>
        <p class="text-xl text-neutral-dark max-w-3xl mx-auto">
          Comprehensive coverage options for businesses and individuals across our 15 licensed states.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Workers' Compensation -->
        <a href="/workers-compensation" class="group bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-all duration-200 border border-neutral-200 hover:border-primary">
          <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-primary group-hover:text-white transition-colors duration-200">
            <svg class="w-6 h-6 text-primary group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-neutral-dark mb-2 group-hover:text-primary transition-colors duration-200">Workers' Compensation</h3>
          <p class="text-neutral-dark mb-4">Essential protection for your employees with competitive rates for all industries.</p>
          <div class="text-primary font-medium group-hover:text-primary-dark">Learn More →</div>
        </a>
        
        <!-- Commercial Auto -->
        <a href="/commercial-auto" class="group bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-all duration-200 border border-neutral-200 hover:border-primary">
          <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-primary group-hover:text-white transition-colors duration-200">
            <svg class="w-6 h-6 text-primary group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a4 4 0 118 0v4m-4 8a2 2 0 11-4 0 2 2 0 014 0zm6 0a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-neutral-dark mb-2 group-hover:text-primary transition-colors duration-200">Commercial Auto</h3>
          <p class="text-neutral-dark mb-4">Complete fleet protection for vehicles of all sizes and types.</p>
          <div class="text-primary font-medium group-hover:text-primary-dark">Learn More →</div>
        </a>
        
        <!-- General Liability -->
        <a href="/general-liability" class="group bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-all duration-200 border border-neutral-200 hover:border-primary">
          <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-primary group-hover:text-white transition-colors duration-200">
            <svg class="w-6 h-6 text-primary group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-neutral-dark mb-2 group-hover:text-primary transition-colors duration-200">General Liability</h3>
          <p class="text-neutral-dark mb-4">Protect against third-party claims and unexpected lawsuits.</p>
          <div class="text-primary font-medium group-hover:text-primary-dark">Learn More →</div>
        </a>
        
        <!-- Business Owner's Policy -->
        <a href="/business-owners-policy" class="group bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-all duration-200 border border-neutral-200 hover:border-primary">
          <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-primary group-hover:text-white transition-colors duration-200">
            <svg class="w-6 h-6 text-primary group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-neutral-dark mb-2 group-hover:text-primary transition-colors duration-200">Business Owner's Policy</h3>
          <p class="text-neutral-dark mb-4">Comprehensive coverage combining liability and property insurance.</p>
          <div class="text-primary font-medium group-hover:text-primary-dark">Learn More →</div>
        </a>
      </div>
    </div>
  </section>
  
  <!-- States We Serve -->
  <section class="py-20 bg-primary-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white mb-4 font-heading">Licensed to Serve You In</h2>
        <p class="text-xl text-primary-100 mb-8">
          Professional insurance services across 15 states with local expertise and national reach.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <span class="bg-white text-primary-dark px-4 py-2 rounded-full font-medium">Alabama</span>
          <span class="bg-white text-primary-dark px-4 py-2 rounded-full font-medium">Arizona</span>
          <span class="bg-white text-primary-dark px-4 py-2 rounded-full font-medium">Florida</span>
          <span class="bg-white text-primary-dark px-4 py-2 rounded-full font-medium">Georgia</span>
          <span class="bg-white text-primary-dark px-4 py-2 rounded-full font-medium">Indiana</span>
          <span class="bg-white text-primary-dark px-4 py-2 rounded-full font-medium">Maryland</span>
          <span class="bg-white text-primary-dark px-4 py-2 rounded-full font-medium">Maine</span>
          <span class="bg-white text-primary-dark px-4 py-2 rounded-full font-medium">New Jersey</span>
          <span class="bg-white text-primary-dark px-4 py-2 rounded-full font-medium">New York</span>
          <span class="bg-white text-primary-dark px-4 py-2 rounded-full font-medium">North Carolina</span>
          <span class="bg-white text-primary-dark px-4 py-2 rounded-full font-medium">Ohio</span>
          <span class="bg-white text-primary-dark px-4 py-2 rounded-full font-medium">Pennsylvania</span>
          <span class="bg-white text-primary-dark px-4 py-2 rounded-full font-medium">Tennessee</span>
          <span class="bg-white text-primary-dark px-4 py-2 rounded-full font-medium">Texas</span>
          <span class="bg-white text-primary-dark px-4 py-2 rounded-full font-medium">Virginia</span>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Why Choose PCFG -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-neutral-dark mb-4 font-heading">Why Choose PCFG Insurance Services?</h2>
        <p class="text-xl text-neutral-dark max-w-3xl mx-auto">
          We combine the personal touch of a local agency with the strength and resources of national carriers.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-neutral-dark mb-2">Veteran-Owned</h3>
          <p class="text-neutral-dark">Founded and operated by veterans who understand the values of service, integrity, and commitment to excellence.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-neutral-dark mb-2">Competitive Rates</h3>
          <p class="text-neutral-dark">We shop multiple top-rated carriers to find you the best coverage at the most competitive rates available.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-neutral-dark mb-2">Expert Support</h3>
          <p class="text-neutral-dark">Dedicated agents and 24/7 claims support ensure you get the help you need when you need it most.</p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-r from-primary to-primary-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Ready to Get Started?</h2>
      <p class="text-xl text-primary-100 mb-8 max-w-2xl mx-auto">
        Get your free quote today and discover why thousands of businesses and families trust PCFG Insurance Services.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#quote-form" class="bg-white text-primary hover:bg-neutral-light px-8 py-3 rounded-lg font-semibold transition-colors duration-200">
          Get Free Quote
        </a>
        <a href="tel:877-717-7234" class="border-2 border-white text-white hover:bg-white hover:text-primary px-8 py-3 rounded-lg font-semibold transition-colors duration-200">
          Call (877) 717-7234
        </a>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>

<script>
  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        target.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  });
</script>