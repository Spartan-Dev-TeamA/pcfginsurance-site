  </section>
  
  <!-- Program Benefits -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-neutral-dark mb-4 font-heading">Benefits for Employers and Employees</h2>
        <p class="text-xl text-neutral-dark max-w-3xl mx-auto">
          The VitalEdge program creates value for both employers and employees through improved health outcomes and cost management.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Employer Benefits -->
        <div class="bg-white p-8 rounded-lg shadow-lg">
          <div class="w-16 h-16 bg-highlight rounded-lg flex items-center justify-center mb-6">
