---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="VitalEdge Program - PCFG Insurance Services" description="Discover the VitalEdge program paired with SB/A MVP Health Plans. Comprehensive employee benefits solution designed to attract and retain top talent while managing costs effectively.">
  <Header />
  
  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-primary-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
        <div>
          <h1 class="text-4xl md:text-5xl font-bold text-neutral-dark mb-6 font-heading">
            VitalEdge Program
          </h1>
          <p class="text-xl text-neutral-dark mb-8">
            Revolutionary employee benefits solution that combines the VitalEdge wellness program with SB/A MVP Health Plans to create a comprehensive, cost-effective benefits package that attracts and retains top talent.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#learn-more" class="bg-primary hover:bg-primary-dark text-white px-8 py-3 rounded-lg font-semibold text-center transition-colors duration-200">
              Learn More
            </a>
            <a href="#vitaledge-form" class="border-2 border-primary text-primary hover:bg-primary-50 px-8 py-3 rounded-lg font-semibold text-center transition-colors duration-200">
              Get Quote
            </a>
          </div>
        </div>
        
        <!-- Program Highlights -->
        <div class="bg-white p-8 rounded-lg shadow-xl">
          <h3 class="text-2xl font-semibold text-neutral-dark mb-6 font-heading">Program Highlights</h3>
          <div class="space-y-4">
            <div class="flex items-start">
              <div class="w-8 h-8 bg-primary rounded-full flex items-center justify-center mr-3 mt-1">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-neutral-dark">Comprehensive Wellness Platform</h4>
                <p class="text-sm text-neutral-dark">24/7 access to health and wellness resources</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="w-8 h-8 bg-primary rounded-full flex items-center justify-center mr-3 mt-1">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-neutral-dark">SB/A MVP Health Plans</h4>
                <p class="text-sm text-neutral-dark">ACA-compliant minimum value plans</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="w-8 h-8 bg-primary rounded-full flex items-center justify-center mr-3 mt-1">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-neutral-dark">Cost-Effective Solution</h4>
                <p class="text-sm text-neutral-dark">Affordable benefits that meet compliance requirements</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="w-8 h-8 bg-primary rounded-full flex items-center justify-center mr-3 mt-1">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-neutral-dark">Employee Engagement</h4>
                <p class="text-sm text-neutral-dark">Tools to improve workforce health and productivity</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- VitalEdge Quote Form -->
      <div id="vitaledge-form" class="max-w-2xl mx-auto">
        <div class="quote-form-container bg-white p-8 rounded-lg shadow-xl">
          <h2 class="text-3xl font-bold text-neutral-dark mb-6 text-center">Get Your VitalEdge Program Quote</h2>
          <iframe
            src="https://api.leadconnectorhq.com/widget/form/EL6vg6rpLnn6rTF4XvTD"
            style="width:100%;min-height:900px;border:none;border-radius:3px"
            id="inline-EL6vg6rpLnn6rTF4XvTD-vitaledge"
            data-layout="{'id':'INLINE'}"
            data-trigger-type="alwaysShow"
            data-trigger-value=""
            data-activation-type="alwaysActivated"
            data-activation-value=""
            data-deactivation-type="neverDeactivate"
            data-deactivation-value=""
            data-form-name="VitalEdge Program - Website"
            data-height="927"
            data-layout-iframe-id="inline-EL6vg6rpLnn6rTF4XvTD-vitaledge"
            data-form-id="EL6vg6rpLnn6rTF4XvTD"
            title="VitalEdge Program - Website"
          >
          </iframe>
          <script src="https://link.msgsndr.com/js/form_embed.js"></script>
        </div>
      </div>
    </div>
  </section>

  <!-- What is VitalEdge -->
  <section id="learn-more" class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-neutral-dark mb-4 font-heading">What is the VitalEdge Program?</h2>
        <p class="text-xl text-neutral-dark max-w-3xl mx-auto">
          VitalEdge is a comprehensive employee wellness and benefits solution that combines cutting-edge wellness technology with affordable health insurance coverage.
        </p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h3 class="text-2xl font-semibold text-neutral-dark mb-6 font-heading">Complete Wellness Platform</h3>
          <p class="text-lg text-neutral-dark mb-6">
            VitalEdge provides your employees with 24/7 access to a comprehensive wellness platform that includes health assessments, personalized wellness plans, fitness tracking, mental health resources, and preventive care tools.
          </p>
          
          <div class="space-y-4">
            <div class="flex items-start">
              <svg class="w-6 h-6 text-primary mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-semibold text-neutral-dark">Health Risk Assessments</h4>
                <p class="text-neutral-dark">Comprehensive health screenings and risk evaluations</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <svg class="w-6 h-6 text-primary mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-semibold text-neutral-dark">Personalized Wellness Plans</h4>
                <p class="text-neutral-dark">Customized health and fitness programs for each employee</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <svg class="w-6 h-6 text-primary mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-semibold text-neutral-dark">Mental Health Support</h4>
                <p class="text-neutral-dark">Access to mental health resources and counseling services</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <svg class="w-6 h-6 text-primary mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-semibold text-neutral-dark">Fitness & Nutrition Tracking</h4>
                <p class="text-neutral-dark">Tools to monitor and improve physical health and nutrition</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="bg-primary-50 p-8 rounded-lg">
          <div class="w-16 h-16 bg-primary rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <h4 class="text-xl font-semibold text-neutral-dark mb-4 font-heading">Employee Benefits</h4>
          <ul class="space-y-3 text-neutral-dark">
            <li class="flex items-center">
              <svg class="w-4 h-4 text-primary mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Improved health outcomes
            </li>
            <li class="flex items-center">
              <svg class="w-4 h-4 text-primary mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Reduced healthcare costs
            </li>
            <li class="flex items-center">
              <svg class="w-4 h-4 text-primary mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Increased productivity
            </li>
            <li class="flex items-center">
              <svg class="w-4 h-4 text-primary mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Better work-life balance
            </li>
            <li class="flex items-center">
              <svg class="w-4 h-4 text-primary mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Enhanced job satisfaction
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
  
  <!-- SB/A MVP Health Plan Integration -->
  <section class="py-20 bg-neutral-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-neutral-dark mb-4 font-heading">Paired with SB/A MVP Health Plans</h2>
        <p class="text-xl text-neutral-dark max-w-3xl mx-auto">
          The VitalEdge program is now integrated with SB/A Minimum Value Plans (MVP), providing a complete benefits solution that meets ACA requirements while keeping costs manageable.
        </p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div class="bg-white p-8 rounded-lg shadow-lg">
          <div class="w-16 h-16 bg-highlight rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
